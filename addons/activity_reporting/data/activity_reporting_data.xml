<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Odoo Connection Parameters for Activity Reporting -->
        <record id="param_odoo_url" model="ir.config_parameter">
            <field name="key">activity_reporting.odoo_url</field>
            <field name="value">http://localhost:8069</field>
        </record>
        
        <record id="param_odoo_username" model="ir.config_parameter">
            <field name="key">activity_reporting.odoo_username</field>
            <field name="value">admin</field>
        </record>
        
        <record id="param_odoo_password" model="ir.config_parameter">
            <field name="key">activity_reporting.odoo_password</field>
            <field name="value">admin</field>
        </record>
    </data>
</odoo>
