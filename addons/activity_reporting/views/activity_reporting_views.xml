<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Activity Reporter Form View -->
    <record id="view_activity_reporter_form" model="ir.ui.view">
        <field name="name">activity.reporter.form</field>
        <field name="model">activity.reporter</field>
        <field name="arch" type="xml">
            <form string="Activity Reporter">
                <header>
                    <button name="action_create_agents" 
                            string="Create Agents" 
                            type="object" 
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_start_agents" 
                            string="Start Agents" 
                            type="object" 
                            class="oe_highlight"
                            invisible="state not in ['configured', 'stopped']"/>
                    <button name="action_stop_agents" 
                            string="Stop Agents" 
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'running'"/>
                    <button name="action_create_bot_user" 
                            string="Create Bot User" 
                            type="object"
                            invisible="state != 'configured' or bot_user_id"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Activity Reporter Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="LLM Configuration">
                            <field name="model_name"/>
                            <field name="base_url"/>
                            <field name="api_key" password="True"/>
                            <field name="base_port"/>
                        </group>
                        <group string="Bot User">
                            <field name="bot_user_id"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Agents">
                            <group>
                                <group string="Orchestrator">
                                    <field name="orchestrator_agent_id"/>
                                </group>
                            </group>
                            <group>
                                <group string="Specialized Agents">
                                    <field name="employee_agent_id"/>
                                    <field name="todo_agent_id"/>
                                    <field name="project_agent_id"/>
                                </group>
                                <group string="">
                                    <field name="timesheet_agent_id"/>
                                    <field name="calendar_agent_id"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Status &amp; Logs">
                            <group>
                                <field name="error_message" readonly="1" invisible="not error_message"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Activity Reporter Tree View -->
    <record id="view_activity_reporter_tree" model="ir.ui.view">
        <field name="name">activity.reporter.tree</field>
        <field name="model">activity.reporter</field>
        <field name="arch" type="xml">
            <list string="Activity Reporters">
                <field name="name"/>
                <field name="state"/>
                <field name="orchestrator_agent_id"/>
                <field name="bot_user_id"/>
            </list>
        </field>
    </record>

    <!-- Activity Reporter Action -->
    <record id="action_activity_reporter" model="ir.actions.act_window">
        <field name="name">Activity Reporters</field>
        <field name="res_model">activity.reporter</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Activity Reporter
            </p>
            <p>
                The Activity Reporter uses a multi-agent system to answer
                questions about current activities across your organization.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_activity_reporting_root"
              name="Activity Reporting"
              sequence="100"/>

    <menuitem id="menu_activity_reporter"
              name="Reporters"
              parent="menu_activity_reporting_root"
              action="action_activity_reporter"
              sequence="10"/>
</odoo>
