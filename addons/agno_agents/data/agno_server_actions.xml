<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="agno_server_action_start_agents" model="ir.actions.server">
        <field name="name">Start Agent(s)</field>
        <field name="model_id" ref="model_agno_agent"/>
        <field name="state">code</field>
        <field name="code">env["agno.action"].start_agents(records)</field>
    </record>

    <record id="agno_server_action_stop_agents" model="ir.actions.server">
        <field name="name">Stop Agent(s)</field>
        <field name="model_id" ref="model_agno_agent"/>
        <field name="state">code</field>
        <field name="code">env["agno.action"].stop_agents(records)</field>
    </record>

    <record id="agno_server_action_refresh_agents" model="ir.actions.server">
        <field name="name">Refresh Agent Status</field>
        <field name="model_id" ref="model_agno_agent"/>
        <field name="state">code</field>
        <field name="code">env["agno.action"].refresh_agents(records)</field>
    </record>

</odoo>
