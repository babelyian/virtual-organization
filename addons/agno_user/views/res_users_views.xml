<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_agno_bot" model="ir.ui.view">
        <field name="name">res.users.form.inherit.agno.bot</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='preferences']" position="inside">
                <group string="Agent Configuration">
                    <field name="is_agno_bot"/>

                    <field name="agno_agent_id"
                           invisible="not is_agno_bot"
                           required="is_agno_bot"
                           options="{'no_create': True}"/>
                    <field name="agno_agent_name" readonly="1" invisible="not agno_agent_id"/>
                    <field name="agno_agent_base_url" readonly="1" invisible="not agno_agent_id"/>
                    <field name="agno_agent_port" readonly="1" invisible="not agno_agent_id"/>

                </group>
            </xpath>
        </field>
    </record>
</odoo>
