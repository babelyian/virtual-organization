<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_agno_broadcast_prompt" model="ir.cron">
        <field name="name">Agno: Broadcast Prompt to Active Agents</field>
        <field name="model_id" ref="model_agno_agent"/>
        <field name="state">code</field>
        <field name="code">env["agno.agent"].cron_broadcast_prompt_to_active_agents(5)</field>
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>

</odoo>
