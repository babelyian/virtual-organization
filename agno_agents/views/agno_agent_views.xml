<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view for Agno Agents -->
    <record id="view_agno_agent_list" model="ir.ui.view">
        <field name="name">agno.agent.list</field>
        <field name="model">agno.agent</field>
        <field name="arch" type="xml">
            <list string="Agno Agents" decoration-success="status=='running'"
                  decoration-danger="status=='error'" decoration-muted="status=='stopped'">
                <field name="agent_name"/>
                <field name="model_id"/>
                <field name="status" widget="badge"/>
                <field name="is_active" widget="boolean_toggle"/>
                <field name="port"/>
                <field name="last_started"/>
                <button name="action_start_agent"
                        type="object"
                        string="Start"
                        class="btn-success"
                        invisible="is_active"
                        icon="fa-play"/>
                <button name="action_stop_agent"
                        type="object"
                        string="Stop"
                        class="btn-danger"
                        invisible="not is_active"
                        icon="fa-stop"/>
            </list>
        </field>
    </record>

    <!-- Form view for Agno Agents -->
    <record id="view_agno_agent_form" model="ir.ui.view">
        <field name="name">agno.agent.form</field>
        <field name="model">agno.agent</field>
        <field name="arch" type="xml">
            <form string="Agno Agent">
                <header>
                    <button name="action_start_agent"
                            type="object"
                            string="Start Agent"
                            class="btn-primary"
                            invisible="is_active"/>
                    <button name="action_stop_agent"
                            type="object"
                            string="Stop Agent"
                            class="btn-secondary"
                            invisible="not is_active"/>
                    <field name="status" widget="statusbar" statusbar_visible="stopped,starting,running,stopping,error"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="agent_name" class="o_text_overflow" placeholder="Agent Name"/>
                        </h1>
                        <h2>
                            <field name="is_active" widget="boolean_toggle"/>
                            <span class="ms-2">Active</span>
                        </h2>
                    </div>
                    
                    <group>
                        <group string="Basic Information">
                            <field name="agent_name"/>
                            <field name="status" readonly="1"/>
                            <field name="port"/>
                            <field name="host"/>
                        </group>
                        <group string="Timing">
                            <field name="last_started" readonly="1"/>
                            <field name="last_stopped" readonly="1"/>
                            <field name="process_pid" readonly="1" invisible="process_pid == 0"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Agent Configuration" name="config">
                            <group>
                                <group string="Agent Properties">
                                    <field name="agent_role" widget="text"/>
                                    <field name="instructions" widget="text"/>
                                </group>
                                <group string="Agent Settings">
                                    <field name="add_history_to_context"/>
                                    <field name="add_datetime_to_context"/>
                                    <field name="markdown"/>
                                    <field name="debug_mode"/>
                                    <field name="num_history_runs"/>
                                    <field name="db_file"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Model Configuration" name="model">
                            <group>
                                <group string="Model Settings">
                                    <field name="model_id"/>
                                    <field name="base_url"/>
                                    <field name="api_key_env"/>
                                </group>
                            </group>
                            <div class="alert alert-info" role="alert">
                                <strong>Note:</strong> Make sure the API key environment variable is set in your system.
                                <br/>Current environment variable: <code><field name="api_key_env" readonly="1"/></code>
                            </div>
                        </page>
                        
                        <page string="Status &amp; Logs" name="status">
                            <group>
                                <field name="error_message" widget="text" readonly="1"
                                       invisible="not error_message"/>
                            </group>
                            <div class="alert alert-warning" role="alert" invisible="not error_message">
                                <strong>Error Details:</strong>
                                <p><field name="error_message" readonly="1"/></p>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban view for Agno Agents -->
    <record id="view_agno_agent_kanban" model="ir.ui.view">
        <field name="name">agno.agent.kanban</field>
        <field name="model">agno.agent</field>
        <field name="arch" type="xml">
            <kanban string="Agno Agents" default_group_by="status">
                <field name="agent_name"/>
                <field name="status"/>
                <field name="is_active"/>
                <field name="model_id"/>
                <field name="port"/>
                <field name="last_started"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <i class="fa fa-robot fa-3x" 
                                   style="color: green;" 
                                   t-if="record.is_active.raw_value"/>
                                <i class="fa fa-robot fa-3x" 
                                   style="color: gray;" 
                                   t-if="!record.is_active.raw_value"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="agent_name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle">
                                    <field name="model_id"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span class="badge badge-pill" 
                                          style="background-color: green;" 
                                          t-if="record.status.raw_value == 'running'">
                                        Running on port <field name="port"/>
                                    </span>
                                    <span class="badge badge-pill" 
                                          style="background-color: red;" 
                                          t-if="record.status.raw_value == 'error'">
                                        Error
                                    </span>
                                    <span class="badge badge-pill" 
                                          style="background-color: gray;" 
                                          t-if="record.status.raw_value == 'stopped'">
                                        Stopped
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_left">
                                    <button name="action_start_agent" 
                                            type="object" 
                                            class="btn btn-primary btn-sm"
                                            t-if="!record.is_active.raw_value">
                                        <i class="fa fa-play"/> Start
                                    </button>
                                    <button name="action_stop_agent" 
                                            type="object" 
                                            class="btn btn-secondary btn-sm"
                                            t-if="record.is_active.raw_value">
                                        <i class="fa fa-stop"/> Stop
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action for Agno Agents -->
    <record id="action_agno_agent" model="ir.actions.act_window">
        <field name="name">Agno Agents</field>
        <field name="res_model">agno.agent</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="views" eval="[
            (ref('view_agno_agent_kanban'), 'kanban'),
            (ref('view_agno_agent_list'), 'list'),
            (ref('view_agno_agent_form'), 'form')
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Agno Agent!
            </p>
            <p>
                Agno Agents are AI-powered assistants that can help with various tasks.
                Configure the agent properties, model settings, and start the agent to make it accessible on the specified port.
            </p>
        </field>
    </record>
</odoo>